{
  "name": "hodor-web",
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.react.config.ts --host",
    "preview": "vite preview --config vite.react.config.ts",
    "build": "tsc -p tsconfig.react.json --noEmit && vite build --config vite.react.config.ts",
    "build-only": "vite build --config vite.react.config.ts",
    "publish:hodor": "yarn build && node scripts/publish-to-hodor.mjs",
    "test:release": "vitest run --config vite.react.config.ts src-react/app/electron-release.test.ts && node --test scripts/publish-to-hodor.test.mjs",
    "test": "vitest run --config vite.react.config.ts",
    "type-check": "tsc -p tsconfig.react.json --noEmit",
    "license": "node scripts/license.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.14",
    "@tanstack/react-router": "^1.170.18",
    "@webav/av-canvas": "^1.2.8",
    "@webav/av-cliper": "^1.2.8",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/license-checker": "^25.0.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.4",
    "jsdom": "^25.0.1",
    "license-checker": "^25.0.1",
    "postcss": "^8.5.20",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  },
